# ant-capsulizer/.env.example
# ----------------------------
# Redis (Job Queue Broker)
# ----------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Queue Names
# ----------------------------
CAPSULE_QUEUE_NAME=capsuleQueue
INQUIRY_QUEUE_NAME=resolver-inquiry
ANT_WORKER_OWNER_SLUG=ant-worker
# Required. Discover via: curl -s http://localhost:4002/v1/owners/ant-worker
ANT_WORKER_OWNER_ID=<required_owner_id>

# ----------------------------
# MySQL (Capsule Database)
# ----------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ant_resolver
DB_USER=root
DB_PASS=
DB_PASSWORD=

# ----------------------------
# Registrar (ant-registrar — issues UUID node IDs)
# ----------------------------
REGISTRAR_BASE_URL=http://localhost:4002

# ----------------------------
# Harvester Runtime (worker.js reads these)
# ----------------------------
USER_AGENT=AgentNet-Capsulizer/1.0 (+https://agentnet.ai)

CONCURRENCY=6
PER_HOST_DELAY_MS=500

MAX_DEPTH=1
MAX_PAGES_PER_SITE=10

SINGLE_PAGE=true

# ----------------------------
# Capture / Output Controls
# ----------------------------
WRITE_SNAPSHOTS=true
VALIDATE_ENVELOPE=true

CG_DETERMINISTIC=false
CG_VERSION=cg-0.5-determinism-ajv-output

ENABLE_LLM=true

# ----------------------------
# Logging
# ----------------------------
LOG_LEVEL=info

# ----------------------------
# OpenAI API (Optional — do NOT commit keys)
# ----------------------------
OPENAI_API_KEY=

# ----------------------------
# Lightweight Web API for ant-orchestrator Web RAG
# ----------------------------
CAPSULIZER_API_PORT=5176
CAPSULIZER_API_TIMEOUT_MS=6000
